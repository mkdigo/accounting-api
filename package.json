{
  "name": "accounting",
  "version": "1.0.0",
  "description": "Accounting system",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "tsx --env-file=.env.development --watch ./src/main.ts",
    "start": "node --env-file=.env.production ./dist/main.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "build:html": "copyfiles -u 1 \"src/**/*.html\" dist",
    "build": "tsc --project tsconfig.prod.json && tsc-alias && npm run build:html",
    "check": "tsc --noEmit",
    "check:prod": "tsc --project tsconfig.prod.json --noEmit",
    "app:secret": "tsx ./src/scripts/create_app_secret.ts",
    "jwt:secret": "tsx ./src/scripts/create_jwt_secret.ts",
    "migrate:dev": "npx dotenv -e .env.development -- npx prisma migrate dev && npx dotenv -e .env.development -- npx prisma generate",
    "prisma:generate": "npx dotenv -e .env.development -- npx prisma generate",
    "prisma:studio": "npx dotenv -e .env.development -- npx prisma studio",
    "db:reset": "npx dotenv -e .env.development -- tsx ./src/scripts/db_reset.ts",
    "db:seed": "npx dotenv -e .env.development -- tsx ./src/scripts/db_seed.ts",
    "db:seed:prod": "node ./dist/scripts/db_seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@mkdigo/datetime": "^2.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "fastify": "^5.8.5",
    "fastify-type-provider-zod": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/json5": "^0.0.30",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "copyfiles": "^2.4.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "json5": "^2.2.3",
    "ts-jest": "^29.4.9",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
